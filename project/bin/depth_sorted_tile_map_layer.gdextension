[configuration]

entry_symbol = "depth_sorted_tile_map_layer"
compatibility_minimum = "4.4"
reloadable = false

[libraries]
; Relative paths ensure that our GDExtension can be placed anywhere in the project directory.
macos.single.debug = "./macos/libdepth_sorted_tile_map_layer.macos.template_debug.dylib"
macos.double.debug = "./macos/libdepth_sorted_tile_map_layer.macos.template_debug.double.dylib"
macos.single.release = "./macos/libdepth_sorted_tile_map_layer.macos.template_release.dylib"
macos.double.release = "./macos/libdepth_sorted_tile_map_layer.macos.template_release.double.dylib"

ios.arm64.single.debug = "./ios/libdepth_sorted_tile_map_layer.ios.template_debug.arm64.dylib"
ios.arm64.double.debug = "./ios/libdepth_sorted_tile_map_layer.ios.template_debug.arm64.double.dylib"
ios.arm64.single.release = "./ios/libdepth_sorted_tile_map_layer.ios.template_release.arm64.dylib"
ios.arm64.double.release = "./ios/libdepth_sorted_tile_map_layer.ios.template_release.arm64.double.dylib"

windows.x86_32.single.debug = "./windows/depth_sorted_tile_map_layer.windows.template_debug.x86_32.dll"
windows.x86_32.double.debug = "./windows/depth_sorted_tile_map_layer.windows.template_debug.x86_32.double.dll"
windows.x86_32.single.release = "./windows/depth_sorted_tile_map_layer.windows.template_release.x86_32.dll"
windows.x86_32.double.release = "./windows/depth_sorted_tile_map_layer.windows.template_release.x86_32.double.dll"

windows.x86_64.single.debug = "./windows/depth_sorted_tile_map_layer.windows.template_debug.x86_64.dll"
