linux.rv64.single.debug = "./linux/libdepth_sorted_tile_map_layer.linux.template_debug.rv64.so"
linux.rv64.double.debug = "./linux/libdepth_sorted_tile_map_layer.linux.template_debug.rv64.double.so"
