windows.x86_64.double.release = "./windows/depth_sorted_tile_map_layer.windows.template_release.x86_64.double.dll"

linux.x86_64.single.debug = "./linux/libdepth_sorted_tile_map_layer.linux.template_debug.x86_64.so"
linux.x86_64.double.debug = "./linux/libdepth_sorted_tile_map_layer.linux.template_debug.x86_64.double.so"
